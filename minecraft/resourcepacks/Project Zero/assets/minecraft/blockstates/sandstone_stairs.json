    { 
      "when": { "OR": [{ "facing": "west", "half": "bottom", "shape": "inner_right" }, {"facing": "north", "half": "bottom", "shape": "inner_left"} ] },      
        "apply": [ 
              { "model": "block/stone/sandstone/stairs/stairs_inner_1", "y": 180 },
            { "model": "block/stone/sandstone/stairs/stairs_inner_2", "y": 180 },
            { "model": "block/stone/sandstone/stairs/stairs_inner_3", "y": 180 },
