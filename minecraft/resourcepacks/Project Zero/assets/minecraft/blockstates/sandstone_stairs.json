            { "model": "block/stone/sandstone/stairs/slope_inner_2", "y": 180 },
            { "model": "block/stone/sandstone/stairs/slope_inner_3", "y": 180 },
            { "model": "block/stone/sandstone/stairs/slope_inner_4", "y": 180 }
        ]
    },
    { 
      "when": { "OR": [{ "facing": "north", "half": "top", "shape": "inner_right" }, {"facing": "east", "half": "top", "shape": "inner_left"} ] },      
        "apply": [ 
              { "model": "block/stone/sandstone/stairs/slope_inner_1", "y": 270 },
            { "model": "block/stone/sandstone/stairs/slope_inner_2", "y": 270 },
            { "model": "block/stone/sandstone/stairs/slope_inner_3", "y": 270 },
            { "model": "block/stone/sandstone/stairs/slope_inner_4", "y": 270 }
        ]
    },

