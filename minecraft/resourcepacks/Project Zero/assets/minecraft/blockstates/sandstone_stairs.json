      "when": { "OR": [{ "facing": "north", "half": "top", "shape": "outer_right" }, {"facing": "east", "half": "top", "shape": "outer_left"} ] },      
        "apply": [ 
              { "model": "block/stone/sandstone/stairs/slope_outer_1", "y": 270 },
            { "model": "block/stone/sandstone/stairs/slope_outer_2", "y": 270 },
            { "model": "block/stone/sandstone/stairs/slope_outer_3", "y": 270 },
            { "model": "block/stone/sandstone/stairs/slope_outer_4", "y": 270 }
        ]
    },

    { 
