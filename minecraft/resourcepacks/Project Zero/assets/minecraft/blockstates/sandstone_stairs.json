{
  "multipart": [
  	{ 
        "when": { "half": "top" },      
        "apply": [ 
            { "model": "block/stone/sandstone/stairs/slope_top_1" },
            { "model": "block/stone/sandstone/stairs/slope_top_2" },
            { "model": "block/stone/sandstone/stairs/slope_top_3" },
            { "model": "block/stone/sandstone/stairs/slope_top_4" }
        ]
    },
    { 
        "when": { "facing": "east", "half": "top", "shape": "straight" },      
        "apply": [ 
            { "model": "block/stone/sandstone/stairs/slope_straight_1", "y": 0 },
            { "model": "block/stone/sandstone/stairs/slope_straight_2", "y": 0 },
            { "model": "block/stone/sandstone/stairs/slope_straight_3", "y": 0 },
            { "model": "block/stone/sandstone/stairs/slope_straight_4", "y": 0 }
        ]
    },
    { 
        "when": { "facing": "south", "half": "top", "shape": "straight" }, 
        "apply": [
            { "model": "block/stone/sandstone/stairs/slope_straight_1", "y": 90 },
            { "model": "block/stone/sandstone/stairs/slope_straight_2", "y": 90 },
            { "model": "block/stone/sandstone/stairs/slope_straight_3", "y": 90 },
            { "model": "block/stone/sandstone/stairs/slope_straight_4", "y": 90 }
        ]
    },
    { 
        "when": { "facing": "west", "half": "top", "shape": "straight" }, 
        "apply": [
            { "model": "block/stone/sandstone/stairs/slope_straight_1", "y": 180 },
            { "model": "block/stone/sandstone/stairs/slope_straight_2", "y": 180 },
            { "model": "block/stone/sandstone/stairs/slope_straight_3", "y": 180 },
            { "model": "block/stone/sandstone/stairs/slope_straight_4", "y": 180 }
        ]
    },
    { 
        "when": { "facing": "north", "half": "top", "shape": "straight" }, 
        "apply": [
            { "model": "block/stone/sandstone/stairs/slope_straight_1", "y": 270 },
            { "model": "block/stone/sandstone/stairs/slope_straight_2", "y": 270 },
            { "model": "block/stone/sandstone/stairs/slope_straight_3", "y": 270 },
            { "model": "block/stone/sandstone/stairs/slope_straight_4", "y": 270 }
        ]
    },
    { 
        "when": { "OR": [{ "facing": "east", "half": "top", "shape": "outer_right" }, {"facing": "south", "half": "top", "shape": "outer_left"} ] },      
        "apply": [ 
            { "model": "block/stone/sandstone/stairs/slope_outer_1", "y": 0 },
            { "model": "block/stone/sandstone/stairs/slope_outer_2", "y": 0 },
            { "model": "block/stone/sandstone/stairs/slope_outer_3", "y": 0 },
            { "model": "block/stone/sandstone/stairs/slope_outer_4", "y": 0 }
        ]
    },
    { 
      "when": { "OR": [{ "facing": "south", "half": "top", "shape": "outer_right" }, {"facing": "west", "half": "top", "shape": "outer_left"} ] },      
        "apply": [ 
              { "model": "block/stone/sandstone/stairs/slope_outer_1", "y": 90 },
            { "model": "block/stone/sandstone/stairs/slope_outer_2", "y": 90 },
            { "model": "block/stone/sandstone/stairs/slope_outer_3", "y": 90 },
            { "model": "block/stone/sandstone/stairs/slope_outer_4", "y": 90 }
        ]
    },
    { 
      "when": { "OR": [{ "facing": "west", "half": "top", "shape": "outer_right" }, {"facing": "north", "half": "top", "shape": "outer_left"} ] },      
        "apply": [ 
              { "model": "block/stone/sandstone/stairs/slope_outer_1", "y": 180 },
            { "model": "block/stone/sandstone/stairs/slope_outer_2", "y": 180 },
            { "model": "block/stone/sandstone/stairs/slope_outer_3", "y": 180 },
            { "model": "block/stone/sandstone/stairs/slope_outer_4", "y": 180 }
