            { "model": "block/stone/sandstone/stairs/slope_inner_2", "y": 90 },
            { "model": "block/stone/sandstone/stairs/slope_inner_3", "y": 90 },
            { "model": "block/stone/sandstone/stairs/slope_inner_4", "y": 90 }
        ]
    },
    { 
      "when": { "OR": [{ "facing": "west", "half": "top", "shape": "inner_right" }, {"facing": "north", "half": "top", "shape": "inner_left"} ] },      
