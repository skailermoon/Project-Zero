{
  "multipart": [
    {
      "when": { "up": "true" },      
        "apply": [ 
          { "model": "create:block/blocks/dripstone/polished_wall/post_1" },
          { "model": "create:block/blocks/dripstone/polished_wall/post_2" }
        ]      
    },
    {
      "when": { "north": "low" },
      "apply": [ 
          { "model": "create:block/blocks/dripstone/polished_wall/side_n_1" },
          { "model": "create:block/blocks/dripstone/polished_wall/side_n_2" }
        ]      
    },
    {
      "when": { "east": "low" },
      "apply": [ 
          { "model": "create:block/blocks/dripstone/polished_wall/side_e_1" },
          { "model": "create:block/blocks/dripstone/polished_wall/side_e_2" }
        ]      
    },
    {
      "when": { "south": "low" },
      "apply": [ 
          { "model": "create:block/blocks/dripstone/polished_wall/side_s_1" },
          { "model": "create:block/blocks/dripstone/polished_wall/side_s_2" }
        ]      
    },
    {
      "when": { "west": "low" },
      "apply": [ 
          { "model": "create:block/blocks/dripstone/polished_wall/side_w_1" },
          { "model": "create:block/blocks/dripstone/polished_wall/side_w_2" }
        ]      
    },
    {
      "when": { "north": "low", "east": "low", "south": "low", "west": "low" },
      "apply": [ 
          { "model": "create:block/blocks/dripstone/polished_wall/cap_1" },
          { "model": "create:block/blocks/dripstone/polished_wall/cap_2" }
        ]      
    },
    {
      "when": { "north": "tall" },
      "apply": [ 
          { "model": "create:block/blocks/dripstone/polished_wall/tall_n_1" },
          { "model": "create:block/blocks/dripstone/polished_wall/tall_n_2" }
        ]      
    },
    {
      "when": { "east": "tall" },
      "apply": [ 
          { "model": "create:block/blocks/dripstone/polished_wall/tall_e_1" },
          { "model": "create:block/blocks/dripstone/polished_wall/tall_e_2" }
        ]      
    },
    {
      "when": { "south": "tall" },
      "apply": [ 
          { "model": "create:block/blocks/dripstone/polished_wall/tall_s_1" },
          { "model": "create:block/blocks/dripstone/polished_wall/tall_s_2" }
        ]      
    },
    {
      "when": { "west": "tall" },
      "apply": [ 
          { "model": "create:block/blocks/dripstone/polished_wall/tall_w_1" },
          { "model": "create:block/blocks/dripstone/polished_wall/tall_w_2" }
        ]      
    }
  ]
}
