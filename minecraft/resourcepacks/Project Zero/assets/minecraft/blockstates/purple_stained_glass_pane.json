{
  "multipart": [
  	{
      "when": { "north": "false", "south": "false", "west": "false", "east": "false" },
      "apply": { "model": "minecraft:block/glass/stained/purple/pane_post" }
    },
    {
      "when": { "north": "true", "south": "true", "west": "false", "east": "false" },
      "apply": { "model": "minecraft:block/glass/stained/purple/pane_straight" }
    },
    {
      "when": { "north": "false", "south": "false", "west": "true", "east": "true" },
      "apply": { "model": "minecraft:block/glass/stained/purple/pane_straight", "y": 90 }
    },

    {
      "when": { "north": "true", "south": "false", "west": "true", "east": "false" },
      "apply": { "model": "minecraft:block/glass/stained/purple/pane_corner", "y": 0 }
    },
    {
      "when": { "north": "true", "south": "false", "west": "false", "east": "true" },
      "apply": { "model": "minecraft:block/glass/stained/purple/pane_corner", "y": 90 }
    },
    {
      "when": { "north": "false", "south": "true", "west": "false", "east": "true" },
      "apply": { "model": "minecraft:block/glass/stained/purple/pane_corner", "y": 180 }
    },
    {
      "when": { "north": "false", "south": "true", "west": "true", "east": "false" },
      "apply": { "model": "minecraft:block/glass/stained/purple/pane_corner", "y": 270 }
    },

    { 
      "when": { "OR": [
      	{ "north": "true", "south": "false", "west": "false", "east": "false" },
      	{ "north": "true", "south": "false", "west": "true", "east": "true" },
      	{ "north": "true", "south": "true", "west": "true", "east": "false" },
      	{ "north": "true", "south": "true", "west": "false", "east": "true" },
      	{ "north": "true", "south": "true", "west": "true", "east": "true" }
      ]},
      "apply": { "model": "minecraft:block/glass/stained/purple/pane_end", "y": 0 }
    },
    { 
      "when": { "OR": [
      	{ "north": "false", "south": "false", "west": "false", "east": "true" },
      	{ "north": "true", "south": "true", "west": "false", "east": "true" },
      	{ "north": "false", "south": "true", "west": "true", "east": "true" },
      	{ "north": "true", "south": "false", "west": "true", "east": "true" },
      	{ "north": "true", "south": "true", "west": "true", "east": "true" }
      ]},
      "apply": { "model": "minecraft:block/glass/stained/purple/pane_end", "y": 90 }
    },
    { 
      "when": { "OR": [
      	{ "north": "false", "south": "true", "west": "false", "east": "false" },
      	{ "north": "false", "south": "true", "west": "true", "east": "true" },
      	{ "north": "true", "south": "true", "west": "true", "east": "false" },
      	{ "north": "true", "south": "true", "west": "false", "east": "true" },
      	{ "north": "true", "south": "true", "west": "true", "east": "true" }
      ]},
      "apply": { "model": "minecraft:block/glass/stained/purple/pane_end", "y": 180 }
    },
    { 
      "when": { "OR": [
      	{ "north": "false", "south": "false", "west": "true", "east": "false" },
      	{ "north": "true", "south": "true", "west": "true", "east": "false" },
      	{ "north": "true", "south": "false", "west": "true", "east": "true" },
      	{ "north": "false", "south": "true", "west": "true", "east": "true" },
      	{ "north": "true", "south": "true", "west": "true", "east": "true" }
      ]},
      "apply": { "model": "minecraft:block/glass/stained/purple/pane_end", "y": 270 }
    },

    {
      "when": { "OR": [
      	{ "north": "true",  "south": "false", "west": "false", "east": "false" },
      	{ "north": "false", "south": "true",  "west": "false", "east": "false" },
      	{ "north": "false", "south": "false", "west": "true",  "east": "false" },
      	{ "north": "false", "south": "false", "west": "false", "east": "true" },
      	{ "north": "true", "south": "true", "west": "true", "east": "true" },
      	{ "north": "false", "south": "true", "west": "true", "east": "true" },
      	{ "north": "true", "south": "false", "west": "true", "east": "true" },
      	{ "north": "true", "south": "true", "west": "false", "east": "true" },
      	{ "north": "true", "south": "true", "west": "true", "east": "false" }
      ]},
      "apply": { "model": "minecraft:block/glass/stained/purple/pane_post" }
    }
  ]
}