          { "model": "minecraft:block/stone/stone_bricks/wall/side_w_4" }
        ]      
    },

    {
      "when": { "west": "low", "south": "low", "east": "low", "north": "low" },
      "apply": [ 
          { "model": "minecraft:block/stone/stone_bricks/wall/cap_1" },
          { "model": "minecraft:block/stone/stone_bricks/wall/cap_2" }
        ]      
    },


    {
      "when": { "north": "tall" },
      "apply": [ 
          { "model": "minecraft:block/stone/stone_bricks/wall/tall_n_1" },
          { "model": "minecraft:block/stone/stone_bricks/wall/tall_n_2" },
          { "model": "minecraft:block/stone/stone_bricks/wall/tall_n_3" },
          { "model": "minecraft:block/stone/stone_bricks/wall/tall_n_4" }
        ]      
    },
    {
      "when": { "east": "tall" },
      "apply": [ 
          { "model": "minecraft:block/stone/stone_bricks/wall/tall_e_1" },
          { "model": "minecraft:block/stone/stone_bricks/wall/tall_e_2" },
          { "model": "minecraft:block/stone/stone_bricks/wall/tall_e_3" },
          { "model": "minecraft:block/stone/stone_bricks/wall/tall_e_4" }
        ]      
    },
    {
      "when": { "south": "tall" },
      "apply": [ 
          { "model": "minecraft:block/stone/stone_bricks/wall/tall_s_1" },
          { "model": "minecraft:block/stone/stone_bricks/wall/tall_s_2" },
