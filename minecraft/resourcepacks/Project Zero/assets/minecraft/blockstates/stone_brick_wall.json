          { "model": "minecraft:block/stone/stone_bricks/wall/side_s_4" }
        ]      
    },
    {
      "when": { "west": "low" },
      "apply": [ 
          { "model": "minecraft:block/stone/stone_bricks/wall/side_w_1" },
          { "model": "minecraft:block/stone/stone_bricks/wall/side_w_2" },
