{
  "multipart": [
    {
      "when": { "up": "true" },      
        "apply": [ 
          { "model": "minecraft:block/stone/stone_bricks/wall/post_1" },
          { "model": "minecraft:block/stone/stone_bricks/wall/post_2" },
          { "model": "minecraft:block/stone/stone_bricks/wall/post_3" },
          { "model": "minecraft:block/stone/stone_bricks/wall/post_4" }
        ]      
    },
    {
      "when": { "north": "low" },
      "apply": [ 
          { "model": "minecraft:block/stone/stone_bricks/wall/side_n_1" },
          { "model": "minecraft:block/stone/stone_bricks/wall/side_n_2" },
          { "model": "minecraft:block/stone/stone_bricks/wall/side_n_3" },
          { "model": "minecraft:block/stone/stone_bricks/wall/side_n_4" }
        ]      
    },
    {
      "when": { "east": "low" },
      "apply": [ 
          { "model": "minecraft:block/stone/stone_bricks/wall/side_e_1" },
          { "model": "minecraft:block/stone/stone_bricks/wall/side_e_2" },
          { "model": "minecraft:block/stone/stone_bricks/wall/side_e_3" },
          { "model": "minecraft:block/stone/stone_bricks/wall/side_e_4" }
        ]      
    },
    {
      "when": { "south": "low" },
      "apply": [ 
          { "model": "minecraft:block/stone/stone_bricks/wall/side_s_1" },
          { "model": "minecraft:block/stone/stone_bricks/wall/side_s_2" },
