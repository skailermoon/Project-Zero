      "apply": [ 
          { "model": "minecraft:block/stone/stone_bricks/wall/tall_w_1" },
          { "model": "minecraft:block/stone/stone_bricks/wall/tall_w_2" },
          { "model": "minecraft:block/stone/stone_bricks/wall/tall_w_3" },
          { "model": "minecraft:block/stone/stone_bricks/wall/tall_w_4" }
