{
  "multipart": [
    {
      "when": { "age": "0" },
      "apply": [
        { "model": "minecraft:block/nature/bamboo/bamboo_1" },
        { "model": "minecraft:block/nature/bamboo/bamboo_2" },
        { "model": "minecraft:block/nature/bamboo/bamboo_3" },
        { "model": "minecraft:block/nature/bamboo/bamboo_4" }
      ]
    },
    {
      "when": { "age": "1" },
      "apply": [
        { "model": "minecraft:block/nature/bamboo/bamboo_1" },
        { "model": "minecraft:block/nature/bamboo/bamboo_2" },
        { "model": "minecraft:block/nature/bamboo/bamboo_3" },
        { "model": "minecraft:block/nature/bamboo/bamboo_4" }
      ]
    },
    {
      "when": { "leaves": "small" },
      "apply": [
          { "model": "minecraft:block/nature/bamboo/leaves_sm_1", "y": 0   },
          { "model": "minecraft:block/nature/bamboo/leaves_sm_1", "y": 90  },
          { "model": "minecraft:block/nature/bamboo/leaves_sm_1", "y": 180 },
          { "model": "minecraft:block/nature/bamboo/leaves_sm_1", "y": 270 }
      ]
    },
    {
      "when": { "leaves": "large" },
      "apply": [
          { "model": "minecraft:block/nature/bamboo/leaves_lg_1", "y": 0  },
          { "model": "minecraft:block/nature/bamboo/leaves_lg_1", "y": 90 },
          { "model": "minecraft:block/nature/bamboo/leaves_lg_2", "y": 0  },
          { "model": "minecraft:block/nature/bamboo/leaves_lg_2", "y": 90 }
      ]
    }
  ]
}
